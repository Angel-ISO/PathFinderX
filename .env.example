# Server Configuration
PORT=3000

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/DatabaseName?retryWrites=true&w=majority&appName=YourAppName

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here_at_least_32_characters
JWT_ISSUER=PathFinderAPI
JWT_EXPIRES_IN=30m

# Email Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_app_password_or_smtp_password

# Redis/Cache Configuration
UPSTASH_REDIS_URL=redis://localhost:6379
# OR for Upstash Redis:
# UPSTASH_REDIS_URL=rediss://default:password@your-redis-instance.upstash.io:6379

# Cache Settings
CACHE_TTL_SECONDS=90

# Optional: Additional Environment Variables
# NODE_ENV=development
# LOG_LEVEL=debug
# API_RATE_LIMIT=100